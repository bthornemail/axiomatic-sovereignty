## facts.o — Local-Binary Executable Register Substrate
## Tier: -2 (FACT) | Edge | Circle | Sphere
## Authority: Grounded hardware vectors — edge/line ingestion

tier: -2
vertex: 1
role: "ingest bytes"

substrate:
  base_4320: "facts.imo % 4320"
  surface_4320_2: "(facts.imo % 4320) * 4320"
  horizon_4320_4: "(facts.imo % 4320) * 4320 * 4320 * 4320"

register:
  left_torque: "ROL64(input, 1)"
  right_torque: "ROR64(axis, 2)"
  blend: "left_torque ^ right_torque"
  output: "blend ^ 0x1D1D1D1D1D1D1D1DULL"
